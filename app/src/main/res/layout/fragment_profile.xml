<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F6"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:text="My Shop Profile"
            android:textColor="#333"
            android:textSize="22sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/profileImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/user_24"
                app:civ_border_color="#4CAF50"
                app:civ_border_width="3dp" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignEnd="@id/profileImage"
                android:layout_alignBottom="@id/profileImage"
                android:background="@android:color/white"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#4CAF50" />
        </RelativeLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            app:cardCornerRadius="15dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <EditText
                    android:id="@+id/ushopname"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Shop Name"
                    android:inputType="textCapWords"
                    android:background="@android:color/transparent"
                    android:drawableStart="@android:drawable/ic_menu_myplaces"
                    android:drawablePadding="10dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE" />

                <EditText
                    android:id="@+id/phone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Phone Number"
                    android:inputType="phone"
                    android:background="@android:color/transparent"
                    android:drawableStart="@android:drawable/ic_menu_call"
                    android:drawablePadding="10dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE" />

                <EditText
                    android:id="@+id/address"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:focusable="false"
                    android:clickable="true"
                    android:hint="Tap to Search Address..."
                    android:background="@android:color/transparent"
                    android:drawableStart="@android:drawable/ic_dialog_map"
                    android:drawablePadding="10dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEE" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/latitude"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:hint="Lat"
                        android:textSize="12sp" />

                    <EditText
                        android:id="@+id/longitude"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:hint="Long"
                        android:textSize="12sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/getLocation"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:text="Use My GPS"
                    android:textAllCaps="false"
                    android:textColor="#4CAF50"
                    android:textSize="12sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/editProfile"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="30dp"
            android:backgroundTint="#4CAF50"
            android:text="Save Profile"
            android:textColor="@android:color/white"
            app:cornerRadius="10dp" />

        <Button
            android:id="@+id/logout"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Logout"
            android:textColor="#F44336" />

    </LinearLayout>
</ScrollView>