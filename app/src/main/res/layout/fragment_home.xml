<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/app_bg">

    <!-- 🔥 TOP ROW (Welcome + Add Button) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/txtWelcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Welcome"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/button_green"/>

        <ImageButton
            android:id="@+id/btnAddCategory"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:background="@drawable/green_circle_bg"
            android:src="@android:drawable/ic_input_add"
            android:tint="@android:color/white"
            android:padding="8dp"/>
    </LinearLayout>

    <!-- 🔍 SEARCH BAR (NOW BELOW) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_margin="10dp"
        android:orientation="horizontal"
        android:background="@color/card_bg"
        android:padding="6dp">

        <EditText
            android:id="@+id/searchBar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"

            android:hint="Find Categories by Speak"

            android:textColor="@color/button_green"
            android:textColorHint="@color/button_green"

            android:focusable="false"
            android:clickable="true"
            android:cursorVisible="false"

            android:background="@null"/>

        <ImageButton
            android:id="@+id/micBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:backgroundTint="@color/mic_bg"
            android:src="@android:drawable/ic_btn_speak_now"
            android:tint="@color/button_green"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- 📦 RECYCLER VIEW -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/categoryRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:scrollbars="vertical"/>

</LinearLayout>